# YantrAI Memory System — Environment Configuration
# install.sh will copy this to .env and fill in your API key + paths.

# OpenAI API key (required — get one at https://platform.openai.com/api-keys)
OPENAI_API_KEY=your-openai-api-key-here

# Model configuration
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_TEXT_MODEL=gpt-4o-mini

# Database paths (install.sh replaces __HOME__ and __REPO__ at install time)
SQLITE_DB_PATH=__HOME__/.productivity-tracker/tracker.db
CHROMADB_PATH=__HOME__/.productivity-tracker/chromadb
PMIS_CHROMADB_PATH=__REPO__/pmis_v2/data/chroma

# Screenshot storage (temporary)
SCREENSHOT_DIR=/tmp/productivity-tracker/frames

# MCP server
MCP_HOST=127.0.0.1
MCP_PORT=8765

# Dashboard API
API_HOST=127.0.0.1
API_PORT=3001
