# YantrAI Memory System — Environment Configuration
# install.sh will copy this to .env and fill in your API key + paths.

# ─── OpenAI access ────────────────────────────────────────────────
# This tracker talks to OpenAI via a proxy your admin operates, NOT directly.
# Your admin will give you a personal access token (format: prome_...) and
# the proxy URL. Paste both below.
#
# The token is yours alone — it has a per-month spend cap, is revocable, and
# is logged. Do not share it or check it into git.
OPENAI_API_KEY=prome_your-personal-access-token-here
OPENAI_BASE_URL=https://prome-openai-proxy.your-account.workers.dev/v1

# Model configuration (the proxy enforces an allowlist; change only with admin coordination)
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_TEXT_MODEL=gpt-4o-mini

# Database paths (install.sh replaces __HOME__ and __REPO__ at install time)
SQLITE_DB_PATH=__HOME__/.productivity-tracker/tracker.db
CHROMADB_PATH=__HOME__/.productivity-tracker/chromadb
PMIS_CHROMADB_PATH=__REPO__/pmis_v2/data/chroma

# Screenshot storage (temporary)
SCREENSHOT_DIR=/tmp/productivity-tracker/frames

# MCP server
MCP_HOST=127.0.0.1
MCP_PORT=8765

# Dashboard API
API_HOST=127.0.0.1
API_PORT=3001
