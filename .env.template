# PMIS environment template. Copy to .env and fill in as needed.
#
#   cp .env.template .env
#
# Everything here is optional. PMIS runs entirely on local Ollama by default
# (see `use_local: true` in pmis_v2/hyperparameters.yaml).

# ─── LLM providers ─────────────────────────────────────────────────────────

# Only needed if you flip `use_local` to false in hyperparameters.yaml, or
# if you set consolidation_model to an Anthropic/OpenAI model name.
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ─── Ollama (local default) ────────────────────────────────────────────────

# Defaults to http://127.0.0.1:11434 — override only if you run Ollama elsewhere.
# OLLAMA_HOST=http://127.0.0.1:11434

# ─── PMIS paths ────────────────────────────────────────────────────────────

# Override where PMIS stores its SQLite DB and ChromaDB index.
# Defaults to pmis_v2/data/memory.db and pmis_v2/data/chroma respectively.
# PMIS_DB_PATH=/Users/you/Desktop/memory/pmis_v2/data/memory.db
# PMIS_CHROMA_DIR=/Users/you/Desktop/memory/pmis_v2/data/chroma

# ─── Ports ────────────────────────────────────────────────────────────────

# Main API + /wiki — defaults to 8100
# PMIS_API_PORT=8100
# Health + feedback + diagnostics + lint — defaults to 8200
# PMIS_HEALTH_PORT=8200
